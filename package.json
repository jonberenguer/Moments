{
  "name": "moments-app",
  "productName": "Moments",
  "private": true,
  "version": "1.5.5",
  "type": "commonjs",
  "description": "Photo & video slideshow editor with GPU-accelerated export",
  "homepage": "https://localhost",
  "author": {
    "name": "Moments",
    "email": "testdev@localhost.localdomain"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder --win --linux",
    "lint": "eslint ."
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.4.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.moments.app",
    "productName": "Moments",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/ffmpeg/fonts/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/${os}",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/ffmpeg/fonts",
        "to": "ffmpeg/fonts",
        "filter": [
          "**/*.ttf",
          "**/*.otf",
          "**/*.ttc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Video",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "_win_target_note": "Windows ships as a per-user NSIS installer (perMachine:false → installs to %LOCALAPPDATA%\\Programs without admin; upgrades the existing install in place via the appId GUID; prefs preserved). NSIS uninstaller-stub generation FAILS when cross-compiling from Linux, so this builds on the windows-latest CI runner (native). For a quick local smoke build on Linux, swap win.target to the preserved _win_portable below.",
  "_win_portable": {
    "target": [
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "public/icon.png"
  }
}
