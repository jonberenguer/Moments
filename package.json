{
  "name": "moments-app",
  "productName": "Moments",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Photo & video slideshow editor with GPU-accelerated export",
  "homepage": "https://localhost",
  "author": {
    "name": "Moments",
    "email": "testdev@localhost.localdomain"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder --win --linux",
    "lint": "eslint ."
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.moments.app",
    "productName": "Moments",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/ffmpeg/fonts/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/${os}",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/ffmpeg/fonts",
        "to": "ffmpeg/fonts",
        "filter": [
          "**/*.ttf"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Video",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "_win_nsis_note": "To use NSIS installer (native Windows builds only), replace win.target portable with the nsis target below",
  "_win_nsis": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "public/icon.png"
  }
}
